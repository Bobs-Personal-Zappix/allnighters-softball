<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Game Scorecard Admin | Allnighters</title>
  <link rel="icon" type="image/png" href="/images/logo.png">
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    .score-input { width:55px; padding:0.4rem 0.3rem; background:var(--dark); border:1px solid var(--border); border-radius:4px; color:var(--text); font-family:'Oswald',sans-serif; font-size:0.85rem; text-align:center; }
    .score-input:focus { outline:none; border-color:var(--gold-dark); }
    .player-row { display:grid; grid-template-columns:30px 180px repeat(10,55px); gap:4px; align-items:center; padding:4px 0; border-bottom:1px solid var(--border); }
    .player-row:hover { background:var(--card-hover); }
    .col-header { font-family:'Oswald',sans-serif; font-size:0.72rem; color:var(--gold); text-transform:uppercase; letter-spacing:0.08em; text-align:center; }
    .order-num { font-family:'Oswald',sans-serif; font-size:0.9rem; color:var(--gold); text-align:center; }
    .player-name { font-size:0.85rem; color:var(--text); padding-left:0.5rem; }
    .pitch-row { display:grid; grid-template-columns:180px repeat(8,65px); gap:4px; align-items:center; padding:4px 0; border-bottom:1px solid var(--border); }
    input[type="password"], select { width:100%; padding:0.65rem 0.9rem; background:var(--dark); border:1px solid var(--border); border-radius:6px; color:var(--text); font-family:'Open Sans',sans-serif; font-size:0.9rem; }
    input[type="password"]:focus, select:focus { outline:none; border-color:var(--gold-dark); }
    .save-bar { position:sticky; bottom:0; background:var(--dark); border-top:2px solid var(--gold-dark); padding:1rem 1.5rem; display:flex; align-items:center; justify-content:space-between; gap:1rem; flex-wrap:wrap; z-index:100; }
  </style>
</head>
<body>
<nav id="navbar">
  <div class="nav-inner">
    <a href="/index.html" class="nav-brand">
      <img src="/images/logo.png" alt="Allnighters Logo">
      <div class="nav-brand-text">Allnighters<span>Scorecard Admin</span></div>
    </a>
  </div>
</nav>

<div class="page-content">
  <div class="page-header">
    <h1 class="page-header-title">Game Scorecard</h1>
    <p class="page-header-sub">Coach Access · Enter Post-Game Stats</p>
  </div>

  <section class="section">
    <div class="container" style="max-width:900px;">

      <!-- Password Screen -->
      <div id="passwordScreen">
        <div style="text-align:center;padding:2rem;background:var(--card);border:1px solid var(--border);border-radius:var(--radius);max-width:400px;margin:0 auto;">
          <div style="font-size:3rem;margin-bottom:1rem;">📋</div>
          <h2 style="font-family:'Oswald',sans-serif;color:var(--gold);font-size:1.4rem;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:0.5rem;">Coach Access</h2>
          <p style="font-size:0.85rem;color:var(--text-muted);margin-bottom:1.5rem;">Enter the coach password to manage scorecards.</p>
          <input type="password" id="passwordInput" placeholder="Password..." onkeydown="if(event.key==='Enter')checkPassword()">
          <button class="btn btn-gold" style="width:100%;margin-top:0.75rem;" onclick="checkPassword()">Enter</button>
          <div id="passwordError" style="color:#C62828;font-size:0.82rem;margin-top:0.75rem;display:none;">Incorrect password.</div>
        </div>
      </div>

      <!-- Admin App -->
      <div id="adminApp" style="display:none;">

        <!-- Game Selector -->
        <div style="margin-bottom:2rem;">
          <div style="font-family:'Oswald',sans-serif;font-size:0.8rem;color:var(--gold);text-transform:uppercase;letter-spacing:0.12em;margin-bottom:0.75rem;">Select Game:</div>
          <select id="gameSelector" onchange="loadGame()">
            <option value="">— Select a game —</option>
          </select>
        </div>

        <!-- Scorecard Form -->
        <div id="scorecardForm" style="display:none;">

          <!-- Game Result -->
          <div style="margin-bottom:2rem;">
            <div class="section-divider" style="font-family:'Oswald',sans-serif;font-size:0.8rem;color:var(--gold);text-transform:uppercase;letter-spacing:0.15em;border-bottom:1px solid var(--border);padding-bottom:0.5rem;margin-bottom:1rem;">Game Result</div>
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:1rem;flex-wrap:wrap;">
              <div>
                <div style="font-size:0.75rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.4rem;">Result</div>
                <select id="gameResult">
                  <option value="">Not Played</option>
                  <option value="W">Win</option>
                  <option value="L">Loss</option>
                  <option value="T">Tie</option>
                </select>
              </div>
              <div>
                <div style="font-size:0.75rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.4rem;">Our Score</div>
                <input type="number" id="scoreUs" min="0" class="score-input" style="width:100%;">
              </div>
              <div>
                <div style="font-size:0.75rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.4rem;">Their Score</div>
                <input type="number" id="scoreThem" min="0" class="score-input" style="width:100%;">
              </div>
              <div>
                <div style="font-size:0.75rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.4rem;">Field</div>
                <select id="gameField">
                  <option value="Marrs Park">Marrs Park</option>
                  <option value="Murphy Park">Murphy Park</option>
                </select>
              </div>
            </div>
          </div>

          <!-- Batting Stats -->
          <div style="margin-bottom:2rem;">
            <div style="font-family:'Oswald',sans-serif;font-size:0.8rem;color:var(--gold);text-transform:uppercase;letter-spacing:0.15em;border-bottom:1px solid var(--border);padding-bottom:0.5rem;margin-bottom:1rem;">⚾ Batting Stats</div>
            <div style="overflow-x:auto;">
              <div style="min-width:700px;">
                <div class="player-row" style="border-bottom:2px solid var(--gold-dark);padding-bottom:6px;">
                  <div class="col-header">#</div>
                  <div class="col-header" style="text-align:left;padding-left:0.5rem;">Player</div>
                  <div class="col-header">PA</div>
                  <div class="col-header">AB</div>
                  <div class="col-header">H</div>
                  <div class="col-header">1B</div>
                  <div class="col-header">2B</div>
                  <div class="col-header">3B</div>
                  <div class="col-header">HR</div>
                  <div class="col-header">RBI</div>
                  <div class="col-header">R</div>
                  <div class="col-header">BB</div>
                </div>
                <div id="battingRows"></div>
              </div>
            </div>
          </div>

          <!-- Pitching Stats -->
          <div style="margin-bottom:2rem;">
            <div style="font-family:'Oswald',sans-serif;font-size:0.8rem;color:var(--gold);text-transform:uppercase;letter-spacing:0.15em;border-bottom:1px solid var(--border);padding-bottom:0.5rem;margin-bottom:1rem;">⚾ Pitching Stats</div>
            <div style="overflow-x:auto;">
              <div style="min-width:600px;">
                <div class="pitch-row" style="border-bottom:2px solid var(--gold-dark);padding-bottom:6px;">
                  <div class="col-header" style="text-align:left;">Pitcher</div>
                  <div class="col-header">IP</div>
                  <div class="col-header">W</div>
                  <div class="col-header">L</div>
                  <div class="col-header">H</div>
                  <div class="col-header">R</div>
                  <div class="col-header">ER</div>
                  <div class="col-header">BB</div>
                  <div class="col-header">K</div>
                </div>
                <div id="pitchingRows"></div>
              </div>
            </div>
          </div>

        </div>

        <!-- Save Bar -->
        <div class="save-bar">
          <div id="saveStatus" style="font-size:0.85rem;color:var(--text-muted);"></div>
          <div style="display:flex;gap:0.75rem;">
            <a href="/scorecard.html" target="_blank" class="btn btn-outline" style="font-size:0.8rem;padding:0.5rem 1rem;">View Scorecard ↗</a>
            <button class="btn btn-gold" onclick="saveScorecard()">💾 Save Scorecard</button>
          </div>
        </div>

      </div>
    </div>
  </section>
</div>

<script src="/js/utils.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script>
const TEAM_PASSWORD = 'allnighters2026';
const SUPABASE_URL  = 'https://gvydowpbvaunpabjwzzr.supabase.co';
const SUPABASE_KEY  = 'sb_publishable_1ZRZFjRbNb5K3c6ecxc4Mg_d_PP_PrG';
const { createClient } = supabase;
const db = createClient(SUPABASE_URL, SUPABASE_KEY);

let roster = [];
let currentGame = null;
let existingScorecard = null;

function checkPassword() {
  if (document.getElementById('passwordInput').value === TEAM_PASSWORD) {
    document.getElementById('passwordScreen').style.display = 'none';
    document.getElementById('adminApp').style.display = 'block';
    sessionStorage.setItem('coach_auth', 'true');
    initAdmin();
  } else {
    document.getElementById('passwordError').style.display = 'block';
  }
}

if (sessionStorage.getItem('coach_auth') === 'true') {
  document.getElementById('passwordScreen').style.display = 'none';
  document.getElementById('adminApp').style.display = 'block';
  initAdmin();
}

async function initAdmin() {
  // Load roster
  const rRes = await fetch('/data/roster-2026.json');
  const rData = await rRes.json();
  roster = rData.players.filter(p => p.name !== 'Player Name');

  // Load schedule to populate game selector
  const sRes = await fetch('/data/schedule-2026.json');
  const sData = await sRes.json();
  const played = sData.games.filter(g => g.result && g.result !== '' && g.result !== 'No Game');

  const sel = document.getElementById('gameSelector');
  played.reverse().forEach(g => {
    const opt = document.createElement('option');
    opt.value = `${g.date}|${g.opponent}`;
    opt.textContent = `${formatDate(g.date)} vs. ${g.opponent} (${g.result} ${g.score_us}-${g.score_them})`;
    sel.appendChild(opt);
  });
}

async function loadGame() {
  const val = document.getElementById('gameSelector').value;
  if (!val) { document.getElementById('scorecardForm').style.display = 'none'; return; }
  
  const [date, opponent] = val.split('|');
  currentGame = { date, opponent };

  // Load lineup for this game if available
  let lineupPlayers = [];
  try {
    const lRes = await fetch('/data/lineup.json');
    const lData = await lRes.json();
    if (lData.game_date === date) {
      // Use saved lineup order
      const allPos = { ...lData.positions };
      const bench = lData.bench || [];
      const ordered = Object.values(allPos)
        .filter(p => p.name)
        .sort((a,b) => (a.order||99) - (b.order||99));
      const benchPlayers = bench.filter(p => p.name);
      lineupPlayers = [...ordered, ...benchPlayers];
    }
  } catch(e) {}

  // Fall back to full roster if no lineup
  if (!lineupPlayers.length) {
    lineupPlayers = roster.map(p => ({ name: p.name, number: p.number, order: 0 }));
  }

  // Check for existing scorecard
  const { data: existing } = await db.from('game_scorecards')
    .select('*').eq('game_date', date).eq('opponent', opponent).single();
  existingScorecard = existing;

  // Populate result fields
  if (existing) {
    document.getElementById('gameResult').value = existing.result || '';
    document.getElementById('scoreUs').value = existing.score_us || '';
    document.getElementById('scoreThem').value = existing.score_them || '';
    document.getElementById('gameField').value = existing.field || 'Marrs Park';
  }

  // Build batting rows
  const battingDiv = document.getElementById('battingRows');
  battingDiv.innerHTML = lineupPlayers.map((p, i) => {
    const existing_p = existing ? (existing.players || []).find(ep => ep.name === p.name) : null;
    const v = (field) => existing_p ? (existing_p[field] || 0) : 0;
    return `
      <div class="player-row">
        <div class="order-num">${p.order || i+1}</div>
        <div class="player-name">${p.name}</div>
        <input type="number" class="score-input" data-player="${p.name}" data-field="pa" value="${v('pa')}" min="0">
        <input type="number" class="score-input" data-player="${p.name}" data-field="ab" value="${v('ab')}" min="0">
        <input type="number" class="score-input" data-player="${p.name}" data-field="h" value="${v('h')}" min="0">
        <input type="number" class="score-input" data-player="${p.name}" data-field="singles" value="${v('singles')}" min="0">
        <input type="number" class="score-input" data-player="${p.name}" data-field="doubles" value="${v('doubles')}" min="0">
        <input type="number" class="score-input" data-player="${p.name}" data-field="triples" value="${v('triples')}" min="0">
        <input type="number" class="score-input" data-player="${p.name}" data-field="hr" value="${v('hr')}" min="0">
        <input type="number" class="score-input" data-player="${p.name}" data-field="rbi" value="${v('rbi')}" min="0">
        <input type="number" class="score-input" data-player="${p.name}" data-field="r" value="${v('r')}" min="0">
        <input type="number" class="score-input" data-player="${p.name}" data-field="bb" value="${v('bb')}" min="0">
      </div>`;
  }).join('');

  // Build pitching rows — find pitchers from roster
  const pitchers = roster.filter(p => p.positions && p.positions.includes('P'));
  const pitchingDiv = document.getElementById('pitchingRows');
  pitchingDiv.innerHTML = pitchers.map(p => {
    const existing_p = existing ? (existing.pitchers || []).find(ep => ep.name === p.name) : null;
    const v = (field) => existing_p ? (existing_p[field] || 0) : 0;
    return `
      <div class="pitch-row">
        <div class="player-name">${p.name}</div>
        <input type="number" class="score-input" data-pitcher="${p.name}" data-field="ip" value="${v('ip')}" min="0" step="0.1">
        <input type="number" class="score-input" data-pitcher="${p.name}" data-field="w" value="${v('w')}" min="0">
        <input type="number" class="score-input" data-pitcher="${p.name}" data-field="l" value="${v('l')}" min="0">
        <input type="number" class="score-input" data-pitcher="${p.name}" data-field="h" value="${v('h')}" min="0">
        <input type="number" class="score-input" data-pitcher="${p.name}" data-field="r" value="${v('r')}" min="0">
        <input type="number" class="score-input" data-pitcher="${p.name}" data-field="er" value="${v('er')}" min="0">
        <input type="number" class="score-input" data-pitcher="${p.name}" data-field="bb" value="${v('bb')}" min="0">
        <input type="number" class="score-input" data-pitcher="${p.name}" data-field="k" value="${v('k')}" min="0">
      </div>`;
  }).join('');

  document.getElementById('scorecardForm').style.display = 'block';
}

async function saveScorecard() {
  if (!currentGame) return;
  const saveBtn = document.querySelector('.btn-gold');
  const saveStatus = document.getElementById('saveStatus');
  saveBtn.textContent = '⏳ Saving...';
  saveBtn.disabled = true;

  // Collect batting stats
  const players = [];
  const playerNames = [...new Set([...document.querySelectorAll('[data-player]')].map(el => el.dataset.player))];
  playerNames.forEach(name => {
    const getVal = (field) => parseInt(document.querySelector(`[data-player="${name}"][data-field="${field}"]`)?.value) || 0;
    players.push({
      name,
      pa:      getVal('pa'),
      ab:      getVal('ab'),
      h:       getVal('h'),
      singles: getVal('singles'),
      doubles: getVal('doubles'),
      triples: getVal('triples'),
      hr:      getVal('hr'),
      rbi:     getVal('rbi'),
      r:       getVal('r'),
      bb:      getVal('bb')
    });
  });

  // Collect pitching stats
  const pitchers = [];
  const pitcherNames = [...new Set([...document.querySelectorAll('[data-pitcher]')].map(el => el.dataset.pitcher))];
  pitcherNames.forEach(name => {
    const getVal = (field) => parseFloat(document.querySelector(`[data-pitcher="${name}"][data-field="${field}"]`)?.value) || 0;
    const ip = getVal('ip');
    const er = getVal('er');
    const era = ip > 0 ? ((er / ip) * 7).toFixed(2) : '—';
    pitchers.push({ name, ip, w: getVal('w'), l: getVal('l'), h: getVal('h'), r: getVal('r'), er, bb: getVal('bb'), k: getVal('k'), era });
  });

  const payload = {
    game_date:  currentGame.date,
    opponent:   currentGame.opponent,
    result:     document.getElementById('gameResult').value,
    score_us:   parseInt(document.getElementById('scoreUs').value) || 0,
    score_them: parseInt(document.getElementById('scoreThem').value) || 0,
    field:      document.getElementById('gameField').value,
    home_away:  'Home',
    players,
    pitchers,
    updated_at: new Date().toISOString()
  };

  const { error } = await db.from('game_scorecards').upsert(payload, { onConflict: 'game_date,opponent' });

  if (error) {
    saveStatus.textContent = '❌ Error saving. Try again.';
    console.error(error);
  } else {
    saveStatus.textContent = '✅ Scorecard saved!';
  }
  saveBtn.textContent = '💾 Save Scorecard';
  saveBtn.disabled = false;
}
</script>
</body>
</html>
